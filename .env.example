# Meta / Instagram（Meta Developer で新規アプリ作成後に設定）
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3000/api/auth/meta/callback
META_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token

# Database (Supabase)
# Connect → Session pooler → URI をコピー（[]は付けない）
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres

# Redis（BullMQ）— docker compose up -d redis
REDIS_URL=redis://localhost:6379

# S3 / Cloudflare R2（予約投稿メディア用）
S3_BUCKET=
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=

# OpenAI（AIレポート）
OPENAI_API_KEY=

# App
NEXTAUTH_SECRET=generate_a_random_secret_here
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=generate_a_random_cron_secret

# ポートフォリオ公開用（true でログイン不要・サンプルデータ表示）
NEXT_PUBLIC_DEMO_MODE=false
